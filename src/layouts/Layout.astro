---
import "../styles/global.css";
import type { Lang } from "../data/translations";

interface Props {
  title: string;
  description: string;
  lang: Lang;
  altLang: Lang;
  altHref: string;
}

const { title, description, lang, altLang, altHref } = Astro.props;
const dir = lang === "ar" ? "rtl" : "ltr";
---

<!doctype html>
<html lang={lang} dir={dir} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;700&family=Mansalva&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap"
      rel="stylesheet"
    />
    <link rel="alternate" hreflang={lang} href={Astro.url.href} />
    <link rel="alternate" hreflang={altLang} href={new URL(altHref, Astro.site ?? Astro.url.origin).href} />
    <title>{title}</title>
  </head>
  <body class="bg-[#F5F5F5] text-stone-900 min-h-screen">
    <slot />
  </body>
</html>
