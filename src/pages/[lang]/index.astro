---
import Layout from "../../layouts/Layout.astro";
import { Navbar } from "../../components/Navbar";
import { RecipeGrid } from "../../components/RecipeGrid";
import { translations, type Lang } from "../../data/translations";

export function getStaticPaths() {
  return [{ params: { lang: "ar" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as Lang;
const altLang: Lang = lang === "ar" ? "en" : "ar";
const t = translations[lang];

const labels = {
  searchPlaceholder: t.searchPlaceholder,
  noResults: t.noResults,
  prep: t.prep,
  cook: t.cook,
  serves: t.serves,
  people: t.people,
  ingredients: t.ingredients,
  instructions: t.instructions,
};
---

<Layout
  title={`${t.siteTitle} — ${lang === "ar" ? "وصفات شرقية" : "Middle Eastern Recipes"}`}
  description={t.heroSubtitle}
  lang={lang}
  altLang={altLang}
  altHref={`/${altLang}/`}
>
  <div class="relative">
    <div class="confetti-bg absolute inset-x-0 top-0 h-[31rem] pointer-events-none opacity-20" />

    <div class="relative">
      <Navbar client:load nav={t.nav} lang={lang} altLang={altLang} activePage="recipes" />

      <header class="text-center px-4 pt-8 pb-6">
        <h1 class="text-[32px] font-mansalva text-[#b93f15] mx-auto leading-snug whitespace-nowrap" style="text-shadow: 0px 1px 3px rgba(0,0,0,0.15), 0px 1px 2px rgba(0,0,0,0.3);">
          {t.heroTitle}
        </h1>
      </header>

      <main id="recipes" class="max-w-6xl mx-auto px-4 py-8">
        <RecipeGrid
          client:load
          recipes={t.recipes}
          categories={t.categories}
          labels={labels}
        />
      </main>
    </div>
  </div>

  <footer
    class="text-center text-stone-400 text-sm py-8 border-t border-stone-100 mt-12"
  >
    {t.footer}
  </footer>
</Layout>
