---
import Layout from "../../layouts/Layout.astro";
import { Navbar } from "../../components/Navbar";
import { OurSouthGrid } from "../../components/OurSouthGrid";
import { translations, type Lang } from "../../data/translations";

export function getStaticPaths() {
  return [{ params: { lang: "ar" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as Lang;
const altLang: Lang = lang === "ar" ? "en" : "ar";
const t = translations[lang];
---

<Layout
  title={`${t.siteTitle} — ${t.ourSouth.pageTitle}`}
  description={t.ourSouth.pageSubtitle}
  lang={lang}
  altLang={altLang}
  altHref={`/${altLang}/our-south`}
>
  <div class="relative">
    <div class="confetti-bg absolute inset-x-0 top-0 h-[20rem] sm:h-[31rem] pointer-events-none opacity-20" />

    <div class="relative">
      <Navbar client:load nav={t.nav} lang={lang} altLang={altLang} activePage="our-south" />

      <header class="text-center px-4 pt-4 sm:pt-8 pb-2">
        <h1
          class={`${lang === "ar" ? "font-aref-ruqaa text-[28px] sm:text-[42px]" : "font-mansalva text-[24px] sm:text-[32px]"} text-black mx-auto leading-snug`}
        >
          {t.ourSouth.pageTitle}
        </h1>
        <p class="mt-2 sm:mt-3 text-black font-heebo text-sm sm:text-base max-w-2xl mx-auto leading-relaxed">
          {t.ourSouth.pageSubtitle}
        </p>
      </header>

      <main class="max-w-6xl mx-auto px-3 sm:px-4 py-6 sm:py-10">
        <OurSouthGrid client:load articles={t.ourSouth.articles} lang={lang} />
      </main>
    </div>
  </div>

  <footer
    class="text-center text-stone-400 text-sm py-6 sm:py-8 border-t border-stone-100 mt-8 sm:mt-12"
  >
    {t.footer}
  </footer>
</Layout>
