---
import Layout from "../../layouts/Layout.astro";
import { Navbar } from "../../components/Navbar";
import { translations, type Lang } from "../../data/translations";

export function getStaticPaths() {
  return [{ params: { lang: "ar" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as Lang;
const altLang: Lang = lang === "ar" ? "en" : "ar";
const t = translations[lang];
---

<Layout
  title={`${t.siteTitle} — ${t.nav.contactUs}`}
  description={t.nav.contactUs}
  lang={lang}
  altLang={altLang}
  altHref={`/${altLang}/contact`}
>
  <div class="relative">
    <Navbar client:load nav={t.nav} lang={lang} altLang={altLang} activePage="contact" />

    <header class="text-center px-4 pt-4 sm:pt-6 pb-0">
      <h1
        class={`${lang === "ar" ? "font-aref-ruqaa text-[28px] sm:text-[42px]" : "font-mansalva text-[24px] sm:text-[36px]"} text-black mx-auto leading-snug`}
      >
        {lang === "ar" ? "شاركوا لنبلط العالم سوا" : "Contribute to Making Al'Blatta Bigger"}
      </h1>
    </header>

    <section class="max-w-[720px] mx-auto px-4 sm:px-8 py-10">
      <iframe
        data-tally-src="https://tally.so/embed/KY0YrV?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
        loading="lazy"
        width="100%"
        height="521"
        frameborder="0"
        marginheight="0"
        marginwidth="0"
        title="Submission Form"
      ></iframe>
      <script>
        var d = document,
          w = "https://tally.so/widgets/embed.js",
          v = function () {
            "undefined" != typeof Tally
              ? Tally.loadEmbeds()
              : d
                  .querySelectorAll("iframe[data-tally-src]:not([src])")
                  .forEach(function (e) {
                    e.src = e.dataset.tallySrc;
                  });
          };
        if ("undefined" != typeof Tally) v();
        else if (d.querySelector('script[src="' + w + '"]') == null) {
          var s = d.createElement("script");
          s.src = w;
          s.onload = v;
          s.onerror = v;
          d.body.appendChild(s);
        }
      </script>
    </section>
  </div>

  <footer
    class="text-center text-stone-400 text-sm py-6 sm:py-8 border-t border-stone-100 mt-8 sm:mt-12"
  >
    {t.footer}
  </footer>
</Layout>
